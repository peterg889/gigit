# Postgres (docker compose default)
DATABASE_URL=postgres://gigit:gigit@localhost:5433/gigit
# >= 32 chars; generate with: openssl rand -hex 32
SESSION_SECRET=dev-session-secret-change-me-0000000000
APP_URL=http://localhost:3000
# local (dev) | s3 (prod)
STORAGE_DRIVER=local
# Required when STORAGE_DRIVER=s3
S3_BUCKET=
AWS_REGION=us-east-1
# Payments rail — discovery-first launch keeps this OFF (Gigit doesn't touch gig
# money; the venue pays the act directly — see docs/pricing.md). Set to true,
# with the Stripe keys below, to turn payments on at monetization.
PAYMENTS_ENABLED=false
# Used only when PAYMENTS_ENABLED=true; otherwise the Null gateway auto-succeeds.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Notifications — unset means structured-log sink (dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
EMAIL_FROM=
# Human support escalations. In production, both this and EMAIL_FROM are required.
SUPPORT_EMAIL_TO=
# AI gateway (Gemini) — unset means heuristic fallbacks only
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
